@model Post

@{
    ViewData["Title"] = Model.Title;
}

<style>
    .content-wrapper {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
        font-family: sans-serif;
    }
    .feature-image{
        width: 100%;
        height: 500px;
        object-fit: cover;
        margin-bottom:20px;
    }
</style>

 <div class="text-end">
     <a class="btn btn-secondary my-3">Editar Post</a>
    <a class="btn btn-danger my-3">Excluir Post</a>
 </div>

<div class="content-wrapper">
    <h1>@Model.Title</h1>
    <p><span class="badge bg-primary">By</span>@Model.Author | <span class="badge bg-primary">Publicado em</span>@Model.PublishedDate.ToString("MMM dd,yyyy")</p>
    <p><span class="badge bg-secondary">Categoria</span>@Model.Category.Name </p>
    <img src="@Model.FeatureImagePath" alt="@Model.Title" class="feature-image"/>
    <hr />
    <div class="">@Html.Raw(@Model.Content)</div>
    <hr />

    @if (Model.Comments.Any())
    {
        <div>
            @foreach(var comment in Model.Comments)
            {
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                    <h5 class="card-title">@comment.UserName</h5>
                    <p class="card-text text-muted">@comment.CommentDate.ToString("MMM dd,yyyy")</p>
                    <p class="card-text ">@comment.Content</p>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">Sem Comentarios. Seja o Primeiro a comentar</p>
    }
</div>